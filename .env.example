# Example .env for mock_warehouse
# Copy to .env and customize values as needed

# Base date used by scripts (YYYY-MM-DD)
BASE_DATE=2026-05-20

# Local DuckDB database path (do NOT commit your real DB)
DB_PATH=mock_warehouse.duckdb

# Output directory for CSV query results
OUTPUT_DIR=outputs

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Runtime flags / tuning (optional)
NUM_SUBSCRIBERS=240
WINDOW_DAYS=120

# Development environment
PYTHON_ENV=development

# Web / scheduling config
REPORT_RECIPIENTS=team@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_SENDER=your_email@example.com
REPORT_RUN_HOUR=7
REPORT_RUN_MINUTE=0
REPORT_TIMEZONE=Africa/Addis_Ababa
